{
  "__inputs": [
    {
      "name": "DS_NEONDB",
      "label": "NeonDB",
      "description": "Your NeonDB PostgreSQL data source",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "ATC Frequencies — Play Store metrics (installs, store performance, ratings)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(daily_device_installs), 0) AS value FROM ps_installs",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Total Installs (all time)",
      "type": "stat"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(MAX(active_device_installs), 0) AS value FROM ps_installs WHERE date = (SELECT MAX(date) FROM ps_installs)",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Active Devices (latest)",
      "type": "stat"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short",
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(store_listing_visitors), 0) AS value FROM ps_store_performance WHERE $__timeFilter(date::timestamptz)",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Store Listing Views",
      "type": "stat"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "green", "value": 20 }
            ]
          },
          "unit": "percent",
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN SUM(store_listing_visitors) > 0 THEN ROUND(100.0 * SUM(store_listing_acquisitions) / SUM(store_listing_visitors), 1) ELSE 0 END AS value FROM ps_store_performance WHERE $__timeFilter(date::timestamptz)",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Install Conversion Rate",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Installs Over Time",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Uninstalls" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT date AS time, SUM(daily_device_installs) AS \"Installs\", SUM(daily_device_uninstalls) AS \"Uninstalls\" FROM ps_installs WHERE $__timeFilter(date::timestamptz) GROUP BY date ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Daily Device Installs / Uninstalls",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT date AS time, SUM(active_device_installs) AS \"Active Devices\" FROM ps_installs WHERE $__timeFilter(date::timestamptz) GROUP BY date ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Active Devices Over Time",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Store Listing Performance",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Acquisitions" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT date AS time, SUM(store_listing_visitors) AS \"Visitors\", SUM(store_listing_acquisitions) AS \"Acquisitions\" FROM ps_store_performance WHERE $__timeFilter(date::timestamptz) GROUP BY date ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Store Listing Visitors vs Installs",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Ratings",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "green", "value": 4 }
            ]
          },
          "unit": "short",
          "decimals": 2,
          "noValue": "No data yet"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(AVG(total_average_rating), 0) AS value FROM ps_ratings WHERE date = (SELECT MAX(date) FROM ps_ratings)",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Current Average Rating",
      "type": "stat"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 2, "min": 1, "max": 5, "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 24 },
      "id": 9,
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT date AS time, AVG(total_average_rating) AS \"Average Rating\" FROM ps_ratings WHERE $__timeFilter(date::timestamptz) GROUP BY date ORDER BY date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Rating Over Time",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Country Breakdown",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 33 },
      "id": 10,
      "options": {
        "xField": "country",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT country, SUM(daily_device_installs) AS \"Installs\" FROM ps_installs WHERE $__timeFilter(date::timestamptz) GROUP BY country ORDER BY 2 DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Top 20 Countries by Installs",
      "type": "barchart"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 33 },
      "id": 11,
      "options": {
        "xField": "country",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT country, SUM(store_listing_visitors) AS \"Visitors\" FROM ps_store_performance WHERE $__timeFilter(date::timestamptz) GROUP BY country ORDER BY 2 DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Top 20 Countries by Store Views",
      "type": "barchart"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 105,
      "title": "Raw Data",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 44 },
      "id": 12,
      "options": {
        "sortBy": [{ "desc": true, "displayName": "Date" }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
          "rawQuery": true,
          "rawSql": "SELECT date AS \"Date\", country AS \"Country\", daily_device_installs AS \"Installs\", daily_device_uninstalls AS \"Uninstalls\", active_device_installs AS \"Active Devices\", total_user_installs AS \"Total Users\" FROM ps_installs WHERE $__timeFilter(date::timestamptz) ORDER BY date DESC, daily_device_installs DESC LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Install Data Table",
      "type": "table"
    }

  ],
  "refresh": "1h",
  "schemaVersion": 38,
  "tags": ["atc-frequencies", "play-store"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ATC Frequencies — Play Store",
  "version": 1
}
