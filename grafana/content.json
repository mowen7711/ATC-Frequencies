{
  "__inputs": [
    {
      "name": "DS_NEONDB",
      "label": "NeonDB",
      "description": "Your existing NeonDB PostgreSQL data source",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "title": "ATC Frequencies — Content & Features",
  "uid": "atcfreq-content",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10m",
  "timezone": "browser",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "tags": [
    "atc-freq"
  ],
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Top 25 Airports Viewed",
      "description": "Most-opened airports. Anonymous and aggregate-only — used to prioritise airport-specific features, not to track individual users.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'icao' AS \"Airport\", COUNT(*) AS \"Views\" FROM atc_metrics WHERE measurement = 'airport_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC LIMIT 25"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top 50 Airports — Full Table",
      "description": "Sortable. Includes airport type so you can spot whether users prefer large hubs or GA fields.",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 14,
        "h": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Views",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Views"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Type"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'icao' AS \"ICAO\", tags->>'type' AS \"Type\", COUNT(*) AS \"Views\", COUNT(DISTINCT install_id) AS \"Unique Users\" FROM atc_metrics WHERE measurement = 'airport_view' AND $__timeFilter(ts) GROUP BY 1, 2 ORDER BY 3 DESC LIMIT 50"
        }
      ]
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Airport Type Breakdown",
      "gridPos": {
        "x": 14,
        "y": 10,
        "w": 10,
        "h": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "pieType": "donut",
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent",
            "value"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'type' AS \"Type\", COUNT(*) AS \"Views\" FROM atc_metrics WHERE measurement = 'airport_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Most Viewed Airport",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "noValue": "—"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'icao' AS \"metric\", COUNT(*) AS value FROM atc_metrics WHERE measurement = 'airport_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Airports Viewed (unique ICAOs)",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "teal"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT tags->>'icao') AS value FROM atc_metrics WHERE measurement = 'airport_view' AND $__timeFilter(ts)"
        }
      ]
    }
  ]
}
