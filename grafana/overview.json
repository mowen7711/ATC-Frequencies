{
  "__inputs": [
    {
      "name": "DS_NEONDB",
      "label": "NeonDB",
      "description": "Your existing NeonDB PostgreSQL data source",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ],
  "title": "ATC Frequencies \u2014 Overview",
  "uid": "atcfreq-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "timezone": "browser",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "tags": [
    "atc-freq"
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "App Opens",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique Installs",
      "gridPos": {
        "x": 3,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT install_id) AS value FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Airports Viewed",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'airport_view' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Frequencies Copied",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "yellow"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'feature_use' AND tags->>'feature' = 'freq_copy' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "SDR Launches",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'feature_use' AND tags->>'feature' = 'sdr_launch' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Avg Session Length",
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "teal"
          },
          "unit": "s",
          "decimals": 0,
          "noValue": "\u2014"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(AVG((fields->>'duration_ms')::bigint) / 1000.0) AS value FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'session_end' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "App Opens Over Time",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 14,
        "h": 9
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts,$__interval), COUNT(*) AS \"App Opens\" FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Daily Unique Installs",
      "gridPos": {
        "x": 14,
        "y": 4,
        "w": 10,
        "h": 9
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT DATE_TRUNC('day', ts) AS time, COUNT(DISTINCT install_id) AS \"Unique Installs\" FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Feature Usage Over Time",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 16,
        "h": 9
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "targets": [
        {
          "refId": "copy",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts,$__interval), COUNT(*) AS \"Freq Copies\" FROM atc_metrics WHERE measurement = 'feature_use' AND tags->>'feature' = 'freq_copy' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1"
        },
        {
          "refId": "airports",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts,$__interval), COUNT(*) AS \"Airport Views\" FROM atc_metrics WHERE measurement = 'airport_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1"
        },
        {
          "refId": "sdr",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts,$__interval), COUNT(*) AS \"SDR Launches\" FROM atc_metrics WHERE measurement = 'feature_use' AND tags->>'feature' = 'sdr_launch' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 10,
      "type": "piechart",
      "title": "App Version Split",
      "gridPos": {
        "x": 16,
        "y": 13,
        "w": 8,
        "h": 9
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "pieType": "donut",
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT fields->>'version' AS \"Version\", COUNT(*) AS \"Opens\" FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC"
        }
      ],
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              {"fieldName": "Version", "handlerKey": "field.name"},
              {"fieldName": "Opens", "handlerKey": "field.value"}
            ]
          }
        }
      ]
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Top Locales",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "orientation": "horizontal",
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        },
        "xField": "Locale"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT fields->>'locale' AS \"Locale\", COUNT(*) AS \"Opens\" FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND fields->>'locale' IS NOT NULL AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC LIMIT 25"
        }
      ],
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              {"fieldName": "Locale", "handlerKey": "field.name"},
              {"fieldName": "Opens", "handlerKey": "field.value"}
            ]
          }
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Most Active Country",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^country$/"
        },
        "colorMode": "background",
        "textMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "noValue": "\u2014"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'geo_country' AS country FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND tags->>'geo_country' IS NOT NULL AND $__timeFilter(ts) GROUP BY 1 ORDER BY COUNT(*) DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Countries Reached",
      "gridPos": {
        "x": 21,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cfofy105jfxtsf"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT tags->>'geo_country') AS value FROM atc_metrics WHERE measurement = 'app_event' AND tags->>'event' = 'app_open' AND tags->>'geo_country' IS NOT NULL AND $__timeFilter(ts)"
        }
      ]
    }
  ]
}