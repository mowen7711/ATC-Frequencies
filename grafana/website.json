{
  "__inputs": [
    {
      "name": "DS_NEONDB",
      "label": "NeonDB",
      "description": "Your existing NeonDB PostgreSQL data source",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ],
  "title": "ATC Frequencies — Website",
  "uid": "atcfreq-website",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "timezone": "browser",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "tags": [
    "atc-freq",
    "website"
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Page Views",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique Visitors",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT install_id) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CTA Clicks",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'cta_click' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reached Bottom of Page (100% scroll)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'scroll_depth' AND tags->>'depth' = '100' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Page Views Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts,$__interval), COUNT(*) AS \"Page Views\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "CTA Clicks by Button",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'target' AS \"Button\", COUNT(*) AS \"Clicks\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'cta_click' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Scroll Depth Funnel",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'depth' || '%' AS \"Depth\", COUNT(*) AS \"Visitors\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'scroll_depth' AND $__timeFilter(ts) GROUP BY 1, (tags->>'depth')::int ORDER BY (tags->>'depth')::int ASC"
        }
      ]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Visitors by Country",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(tags->>'geo_country', 'Unknown') AS \"Country\", COUNT(*) AS \"Page Views\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC LIMIT 20"
        }
      ]
    }
  ]
}
