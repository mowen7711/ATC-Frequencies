{
  "__inputs": [
    {
      "name": "DS_NEONDB",
      "label": "NeonDB",
      "description": "Your existing NeonDB PostgreSQL data source",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "geomap",
      "name": "Geomap",
      "version": ""
    }
  ],
  "title": "ATC Frequencies — Website",
  "uid": "atcfreq-website",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "timezone": "browser",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "tags": [
    "atc-freq",
    "website"
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Page Views",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique Visitors",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT install_id) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CTA Clicks",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'cta_click' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reached Bottom of Page (100% scroll)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'scroll_depth' AND tags->>'depth' = '100' AND $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Page Views Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(ts,$__interval), COUNT(*) AS \"Page Views\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "CTA Clicks by Button",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'target' AS \"Button\", COUNT(*) AS \"Clicks\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'cta_click' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Scroll Depth Funnel",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT tags->>'depth' || '%' AS \"Depth\", COUNT(*) AS \"Visitors\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'scroll_depth' AND $__timeFilter(ts) GROUP BY 1, (tags->>'depth')::int ORDER BY (tags->>'depth')::int ASC"
        }
      ]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Visitors by Country",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(tags->>'geo_country', 'Unknown') AS \"Country\", COUNT(*) AS \"Page Views\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC LIMIT 20"
        }
      ]
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Traffic Sources",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "orientation": "horizontal",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(tags->>'referrer_source', 'Unknown') AS \"Source\", COUNT(*) AS \"Page Views\" FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND $__timeFilter(ts) GROUP BY 1 ORDER BY 2 DESC LIMIT 20"
        }
      ]
    },
    {
      "id": 10,
      "type": "geomap",
      "title": "Visitors — Map",
      "description": "City-level location from Cloudflare IP geolocation. No GPS data collected.",
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 18 },
      "datasource": { "type": "postgres", "uid": "cfofy105jfxtsf" },
      "options": {
        "view": { "id": "zero", "lat": 30, "lon": 0, "zoom": 2 },
        "controls": { "mouseWheelZoom": true, "showZoom": true, "showAttribution": true },
        "layers": [
          {
            "type": "default",
            "name": "Basemap",
            "config": { "showLabels": true }
          },
          {
            "type": "markers",
            "name": "Visitors",
            "config": {
              "style": {
                "size": { "fixed": 8, "min": 5, "max": 25, "field": "visits" },
                "color": { "fixed": "dark-blue" },
                "fillOpacity": 0.7,
                "symbol": { "mode": "fixed", "fixed": "img/icons/marker/circle.svg" }
              },
              "showLegend": true
            },
            "location": { "mode": "coords", "latitude": "latitude", "longitude": "longitude" },
            "tooltip": true
          }
        ],
        "tooltip": { "mode": "details" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "dark-blue" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "visits" },
            "properties": [
              { "id": "displayName", "value": "Visits" },
              { "id": "custom.hideFrom", "value": { "tooltip": false, "viz": false, "legend": false } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT (tags->>'geo_lat')::float AS latitude, (tags->>'geo_lon')::float AS longitude, tags->>'geo_city' AS city, tags->>'geo_country' AS country, COUNT(*) AS visits FROM atc_metrics WHERE measurement = 'web_event' AND tags->>'event' = 'page_view' AND tags->>'geo_lat' IS NOT NULL AND tags->>'geo_lon' IS NOT NULL AND $__timeFilter(ts) GROUP BY 1, 2, 3, 4 ORDER BY 5 DESC"
        }
      ]
    }
  ]
}
